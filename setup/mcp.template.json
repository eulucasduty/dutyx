{
  "mcpServers": {
    "meu-mcp-local": {
      "type": "stdio",
      "command": "node",
      "args": ["caminho/para/o/servidor-mcp.js"],
      "env": {
        "API_KEY": "COLOQUE_SUA_CHAVE_AQUI"
      }
    },
    "meu-mcp-remoto": {
      "type": "http",
      "url": "https://exemplo.com/mcp",
      "headers": {
        "Authorization": "Bearer COLOQUE_SUA_CHAVE_AQUI"
      }
    }
  }
}
